# Faceplica

PREFIX      = /opt/apotheca
FONTES      = persona.c artista.c bestia.c
CAPITA      = persona.h artista.h bestia.h communia.h
OBJECTA     = $(FONTES:.c=.o)
BIBLIOTHECA = libproplasma.a

omnia: $(BIBLIOTHECA) promptum

%.o: %.c $(CAPITA)
	ccc $<

$(BIBLIOTHECA): $(OBJECTA)
	ar rcs $@ $^

promptum: promptum.o $(BIBLIOTHECA)
	ldi $^

proba_prima: proba_prima.o $(BIBLIOTHECA)
	ldi $^

proba: proba_prima
	./proba_prima

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 promptum $(PREFIX)/bin
	install -d $(PREFIX)/lib $(PREFIX)/include/proplasma
	install -m 644 $(BIBLIOTHECA) $(PREFIX)/lib/
	install -m 644 $(CAPITA) $(PREFIX)/include/proplasma/

purga:
	rm -f $(OBJECTA) promptum.o $(BIBLIOTHECA) promptum \
	      proba_prima.o proba_prima

linte:
	insinulint -c $(FONTES) promptum.c $(CAPITA)

.PHONY: omnia colloca purga linte proba
